def extract_sections_dynamic(text: str, headers: list[str]) -> list[dict]:
    matches = []
    lines=text.splitlines()
    new_lines=[]
    for line in lines:
        fixed=False
        for h in headers:
            synonyms=[syn.strip() for syn in h.split(",") if syn.strip()]
            for syn in synonyms:
                syn_text=syn.strip()
                if line.lower().startswith(syn_text.lower()+ ":") and line.strip() != syn_text + ":":
                    header_part=syn_text
                    rest_part=line[len(syn_text)+1:].strip()
                    new_lines.append(header_part)
                    if rest_part:
                        new_lines.append(rest_part)
                    fixed= True
                    break
            if fixed:
                break
        if not fixed:
            new_lines.append(line)          
    lines=new_lines
    char_offset=0
    window_size=3
    i=0
    max_head_len=5
    while i<len(lines):
        for w in range(1,window_size+1):
            if i+w>len(lines):
                continue
            merged_lines=" ".join([lines[j].strip() for j in range(i,i+w)]) 
            for h in headers:
                synonyms=[syn.strip() for syn in h.split(",") if syn.strip()]
                matched= False
                for syn in synonyms:
                    pattern = normalize_header_for_regex(syn)
                    # line_text=lines[i].strip().lower()
                    # syn_text=syn.strip().lower()
                    # line_words=line_text.split()
                    # if not line_text.startswith(syn_text) or len(line_words) > max_head_len:
                    #     continue
                    line_text=merged_lines.strip().lower()
                    syn_text=syn.strip().lower()
                    line_words=line_text.split()
                    if not line_text.startswith(syn_text) or len(line_words) > max_head_len:
                        continue
                    # first_word=syn.strip().split()[0]
                    # first_line_word=lines[i].strip().split()[0] if lines[i].strip() else ""
                    # if first_word.lower() !=first_line_word.lower():
                    #     continue
                    
                    pattern=r"^"+pattern+r"\b"
                    if re.match(pattern,merged_lines, re.IGNORECASE):
                        start_idx=char_offset
                        end_idx=char_offset+sum(len(lines[i+k])+1 for k in range(w))
                        matches.append((start_idx, end_idx, synonyms[0]))
                        matched=True
                        break
                if matched:
                    break
            if matched:
                break
        char_offset+=len(lines[i])+1
        i+=1
                        

    if not matches:
        return []

    matches.sort(key=lambda x: x[0])

    extracted = []
    for i, (start_idx, end_idx, header) in enumerate(matches):
        if i + 1 < len(matches):
            next_start_idx = matches[i + 1][0]
            content = text[end_idx:next_start_idx].strip()
            extracted.append({
                "section": header,
                "content": content
            })
        else:
            content = text[end_idx:].strip()
            extracted.append({
                "section": f"{header}",
                "content": content
            })

    return extracted

def extract_date_visit_sections(final_text: str):
    import re

    date_pattern = re.compile(
        r"Date\s*of\s*Service\s*:?\s*\n?\s*"
        r"(\d{1,2}/\d{1,2}/\d{2,4}\s+\d{1,2}:\d{2}\s*(?:AM|PM))",
        flags=re.IGNORECASE
    )
    visit_pattern = re.compile(
        r"\b(H\s*&\s*[A-Z]*P|History\s*&\s*Physical|Discharge\s*Summary|"
        r"Progress\s*Notes?|Consults?|Procedures?|ACP?|Code Documentation?)\b",
        flags=re.IGNORECASE
    )
    end_pattern = re.compile(r"(Care\s+Timeline)", flags=re.IGNORECASE)
    page_pattern = re.compile(r"---\s*Page\s+(\d+)\s*\(.*?\)\s*---", flags=re.IGNORECASE)

    words = final_text.split()
    sections = {}
    matches = []

    # find all date of service occurrences
    for m in date_pattern.finditer(final_text):
        date_str = m.group(1)
        start_idx = m.start()
        word_index = len(final_text[:start_idx].split())
        matches.append({
            "date": date_str,
            "word_index": word_index,
            "char_index": start_idx
        })

    if not matches:
        return {}

    for i, m in enumerate(matches):
        date_str = m["date"]
        word_index = m["word_index"]

        # nearest visit type
        nearest_visit = None
        for vm in visit_pattern.finditer(final_text):
            v_word_idx = len(final_text[:vm.start()].split())
            if abs(v_word_idx - word_index) <= 50:
                nearest_visit = vm.group(0).strip()
                break

        if not nearest_visit:
            continue

        start = m["char_index"]

        # default end = next date
        if i + 1 < len(matches):
            end = matches[i + 1]["char_index"]
        else:
            end = len(final_text)

        # search area for page and end markers
        search_area = final_text[start:end]

        # ✅ STEP 1: Find page number *before* truncating by Care Timeline
        page_match = page_pattern.search(search_area)
        if page_match:
            page_no = page_match.group(1)
        else:
            page_no = "Unknown"

        # ✅ STEP 2: Now check for "Care Timeline" and truncate after
        end_match = end_pattern.search(search_area)
        if end_match:
            end = start + end_match.start()

        section_text = final_text[start:end].strip()
        section_text = remove_chunk_data_AHFL(section_text)

        # handle page number safely
        try:
            page_no_int = int(page_no)
            page_no_final = page_no_int - 1
        except (ValueError, TypeError):
            page_no_final = "Unknown"

        header_name = f"Date_of_Service_{date_str}_{nearest_visit.replace(' ', '_')}_Page_{page_no_final}"
        sections[header_name] = section_text

    return sections

def remove_chunk_data_AHFL(chart):
    # Common footer/header strings and PHI indicators
    chart = chart.replace("https://carelink.adventhealth.com/EpicCareLink-PRD/common/epic_main.asp", "")
    chart = chart.replace("htpslIcarelinkadventhealth.com/EpicCareLink-PRDIcommonlepic_main.asp 2/11", "")
    
    # Patterns to remove
    remove_patterns = [
        r"---\s*PAGE\s*\d+\s*---",                        # Matches page headers like --- PAGE 6 ---
        r"\d+/\d+/\d{2,4}, \d+:\d+ (AM|PM)",              # Timestamps like 10/9/24, 3:40 AM
        r"Printed by.*",                                  # Footer like Printed by ROJA
        r"User name.*",
        r"User ID.*",
        r"Patient MRN.*",
        r"Patient name.*",
        r"Date of Birth.*",
        r"MRN.*",
        r"DOB.*",
        r"ht.*carelink.*",                                # Any variation of carelink URLs
        r"^\s*name\s*$",                                  # Lines with just "name"
        r"^\s*\d+/\d+\s*$"                                # Lines like "2/11"
    ]

    combined_pattern = re.compile("|".join(remove_patterns), re.IGNORECASE)

    # Remove all lines matching the pattern
    cleaned_lines = [line for line in chart.splitlines() if not combined_pattern.search(line)]
    cleaned_chart = "\n".join(cleaned_lines)

    return cleaned_chart

