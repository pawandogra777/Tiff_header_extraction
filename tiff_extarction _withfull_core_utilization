        img_seq.seek(i)
        pages_list.append(img_seq.copy())

    # ---------------- OCR PER PAGE PARALLEL ----------------
    def process_page(page):
        page = page.convert("RGB")
        page = page.resize((1250,1544), Image.LANCZOS)
        result = ocr_model([np.array(page)])
        return page, result.pages[0]

    pages_results = Parallel(n_jobs=16, backend="loky", verbose=10)(
        delayed(process_page)(p) for p in pages_list
