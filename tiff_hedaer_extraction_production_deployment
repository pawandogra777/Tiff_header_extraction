def get_chart_list_from_chartmaster(
        collection,        
        file_process
    ):
    cursor = collection.find(
        {
           
            "file_name":  {"$in": file_process}
        },
        {
            "_id": 0,
            "file_name": 1,
            "pageCount": 1
        }
    )

    return [
        {"file": doc["file_name"], "pageCount": doc.get("pageCount", "0")}
        for doc in cursor
    ]


