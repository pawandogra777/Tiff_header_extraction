        for local_idx, (img, doctr_page) in enumerate( pages_results):
            page_num = target_pages[local_idx]
            width, height = img.size
            img_np = np.array(img)
            img_gray = cv2.cvtColor(img_np, cv2.COLOR_RGB2GRAY)

            data_rows = []
            for block in doctr_page.blocks:
                for line in block.lines:
                    for word in line.words:
                        ((x_min, y_min), (x_max, y_max)) = word.geometry
                        left = int(x_min * width)
                        top = int(y_min * height)
                        data_rows.append({'text': word.value, 'left': left, 'top': top})
            data = pd.DataFrame(data_rows)
            if data.empty:
                continue
            data = data.reset_index(drop=True)

            if h_img is None or w_img is None:
                h_img, w_img = img_gray.shape

            if is_full_table_page(data, height):
                print(f"Table detected on Page {page_num + 1}")
                if accumulated_col1 or accumulated_col2:
                    combined = accumulated_col2 + accumulated_col1
                    chart_pages.append(
                        f"\n\n--- Columnar Block (before Page {page_num + 1}) ---\n" + "\n".join(combined)
                    )
                    accumulated_col1, accumulated_col2 = [], []

                table_rows = parse_table_lines_from_data(data, col_gap_threshold, line_tolerance)
                lines = [" ".join(row) for row in table_rows]
                p =f"\n--- Page {page_num + 1} (Table Page) ---\n" + "\n".join(lines)
                chart_pages.append(p)
                #--------------------------------------------------------------------------
                checklist = ['medication orders','last mar event','dose/volume']
                med_page = sum(check_w in p.lower() for check_w in checklist)
                if med_page >= 2:
                    medicine_inx.append(page_num+1)
                    base_filename = os.path.splitext(os.path.basename(tif_path))[0]
                    save_fol = medFolder
                    os.makedirs(save_fol, exist_ok=True)
                    output_path = os.path.join(save_fol, f"{base_filename}_{page_num + 1}.tif")
                    all_pages_pil[page_num].save(output_path, "tiff")


            # ---------- CASE 2: COLUMNAR PAGE ----------
            else:
                print(f"Columnar page detected on Page {page_num + 1}")
                corrected_line_nums = []
                current_line_num = 1
                prev_top = None
                for _, row in data.iterrows():
                    curr_top = row['top']
                    if prev_top is None or abs(curr_top - prev_top) > line_tolerance:
                        current_line_num += 1
                    corrected_line_nums.append(current_line_num)
                    prev_top = curr_top
                data['corrected_line_num'] = corrected_line_nums

                chart_lines_col1, chart_lines_col2 = [], []
                grouped = data.groupby('corrected_line_num')

                for _, group in grouped:
                    words = group.reset_index(drop=True)
                    line_text = ""
                    col2_text = ""
                    prev_left = None
                    first_left = words.loc[0, 'left']

                    if first_left > 1315:
                        for _, row in words.iterrows():
                            line_text += (" " if line_text else "") + row['text']
                    else:
                        switched_to_col1 = False
                        current_line = words['corrected_line_num'].iloc[0]
                        for _, row in words.iterrows():
                            curr_left = row['left']
                            word = row['text']
                            line_num = row['corrected_line_num']
                            if not switched_to_col1:
                                if prev_left is not None and (curr_left - prev_left) > gap_threshold and curr_left > (width // 2):
                                    switched_to_col1 = True
                                    line_text += word
                                else:
                                    col2_text += (" " if col2_text else "") + word
                            else:
                                if line_num == current_line:
                                    line_text += (" " if line_text else "") + word
                                else:
                                    break
                            prev_left = curr_left

                    if line_text:
                        for line in line_text.strip().split('\n'):
                            accumulated_col1.append(line.strip())
                    if col2_text:
                        for line in col2_text.strip().split('\n'):
                            accumulated_col2.append(line.strip())

                #  Append page number explicitly for columnar pages too
                if accumulated_col1 or accumulated_col2:
                    combined = accumulated_col2 + accumulated_col1
                    p =  f"\n\n--- Page {page_num + 1} (Columnar Page) ---\n" + "\n".join(combined)
                    chart_pages.append(p)
                    accumulated_col1, accumulated_col2 = [], []
                    #--------------------------------------------------------------------------
                    checklist = ['medication orders','last mar event','dose/volume']
                    med_page = sum(check_w in p.lower() for check_w in checklist)
                    if med_page >= 2:
                        medicine_inx.append(page_num+1)
                        base_filename = os.path.splitext(os.path.basename(tif_path))[0]
                        save_fol = medFolder
                        os.makedirs(save_fol, exist_ok=True)
                        output_path = os.path.join(save_fol, f"{base_filename}_{page_num + 1}.tif")
