def remove_chunk_data_AHFL(chart):
    # Common footer/header strings and PHI indicators
    chart = chart.replace("https://carelink.adventhealth.com/EpicCareLink-PRD/common/epic_main.asp", "")
    chart = chart.replace("htpslIcarelinkadventhealth.com/EpicCareLink-PRDIcommonlepic_main.asp 2/11", "")
    
    # Patterns to remove
    remove_patterns = [
        r"---\s*PAGE\s*\d+\s*---",                        # Matches page headers like --- PAGE 6 ---
        r"\d+/\d+/\d{2,4}, \d+:\d+ (AM|PM)",              # Timestamps like 10/9/24, 3:40 AM
        r"Printed by.*",                                  # Footer like Printed by ROJA
        r"User name.*",
        r"User ID.*",
        r"Patient MRN.*",
        r"Patient name.*",
        r"Date of Birth.*",
        r"MRN.*",
        r"DOB.*",
        r"ht.*carelink.*",                                # Any variation of carelink URLs
        r"^\s*name\s*$",                                  # Lines with just "name"
        r"^\s*\d+/\d+\s*$"                                # Lines like "2/11"
    ]

    combined_pattern = re.compile("|".join(remove_patterns), re.IGNORECASE)

    # Remove all lines matching the pattern
    cleaned_lines = [line for line in chart.splitlines() if not combined_pattern.search(line)]
    cleaned_chart = "\n".join(cleaned_lines)

    return cleaned_chart

