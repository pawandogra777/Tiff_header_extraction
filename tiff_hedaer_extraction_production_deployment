# Excel se headers + synonyms load karna
def load_headers_from_excel(excel_path: str):
    df = pd.read_excel(excel_path)
    headers = []
    for cell in df['header'].dropna().tolist():
        # split by comma, strip extra spaces
        parts = [p.strip() for p in str(cell).split(",") if p.strip()]
        headers.extend(parts)
    return headers

def is_full_table_page(data, page_height, word_count_thresh=10000, std_left_thresh=437):
    data_filtered = data[data['top'] > 0]
    return len(data_filtered) < word_count_thresh and data_filtered['left'].std() > std_left_thresh

def parse_table_lines_from_data(data, col_gap_threshold=80, line_tolerance=5):
    data = data.reset_index(drop=True)
    corrected_line_nums = []
    current_line_num = 1
    prev_top = None
    for _, row in data.iterrows():
        curr_top = row['top']
        if prev_top is None or abs(curr_top - prev_top) > line_tolerance:
            current_line_num += 1
        corrected_line_nums.append(current_line_num)
        prev_top = curr_top
    data['corrected_line_num'] = corrected_line_nums

    table_rows = []
    grouped = data.groupby('corrected_line_num')
    for _, group in grouped:
        words = group.reset_index(drop=True)
        row = []
        prev_left = None
        cell = ""
        for _, word_row in words.iterrows():
            curr_left = word_row['left']
            word = word_row['text']
            if prev_left is not None and (curr_left - prev_left) > col_gap_threshold:
                row.append(cell.strip())
                cell = word
            else:
                cell += " " + word if cell else word
            prev_left = curr_left
        if cell:
            row.append(cell.strip())
        table_rows.append(row)
    return table_rows

def normalize_header_for_regex(header: str) -> str:
    header = header.strip()
    header = re.sub(r"&", r"(?:&\.?|and)", header, flags=re.IGNORECASE)
    header = re.sub(r"\s+", r"\\s+", header)
    return header

