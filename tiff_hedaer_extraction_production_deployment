def get_Page_Starts(final_text):
    page_pattern = re.compile(r'\n\s*---\s*Page\s+\d+.*?---\s*\n')

    page_starts = [0]  # Page 1 starts at index 0

    for match in page_pattern.finditer(final_text):
        page_starts.append(match.end())
    return page_starts

def extract_date_visit_sections(final_text: str):
    # date_pattern = re.compile(
    # r"Date\s*of\s*Service\s*:?\s*"
    # r"(?P<date>\d{1,2}/\d{1,2}/\d{2,4})"    # date part
    # r"(?:\s*Status\s*:\s*\w+)?\s*"          # optional 'Status: Signed'
    # r"\n?\s*(?P<time>\d{1,2}:\d{2}(?::\d{2})?\s*(?:AM|PM)?)",  # time on same or next line
    # flags=re.IGNORECASE
    # )

    date_pattern = re.compile(
        r"(?:REP\s*SRV\s*DT\s*[:,]?\s*"     # 'REP SRV DT', optional ':' or ',' 
        r"(?:\n\s*)?"                        # optional newline before date
        r"|(?:\d+\.\s*)?DATE\s*OF\s*SERVICE\s*[:,]?\s*)"  # optional '1.' or any number followed by 'DATE OF SERVICE'
        r"(?P<date>\d{1,2}/\d{1,2}/\d{2,4})",   # the date
        flags=re.IGNORECASE
    )

    visit_pattern = re.compile(
        r"\b(H\s*&\s*[A-Z]*P|History\s*&\s*Physical|History\s*and\s*Physical|Discharge\s*Summary|Procedure?|Progress\s*Notes?|Consultation?|Consults?)\b",
        flags=re.IGNORECASE
    )
    end_pattern = re.compile(
        r"END\s*[O0]\s*F\s*REPORT",   # clean + OCR variants
        flags=re.IGNORECASE
    )
    page_pattern = re.compile(r"---\s*Page\s+(\d+)\s*\(.*?\)\s*---", flags=re.IGNORECASE)

    words = final_text.split()
    sections = {}
    matches = []
    page_Start_Index_list = get_Page_Starts(final_text)
    # find all date occurrences
    for m in date_pattern.finditer(final_text):
        date_str = m.group("date")

        # ---- FIXED (do NOT break logic, just avoid crash) ----
        time_str = m.groupdict().get("time", "")
        if time_str:
            time_str = time_str.replace("\n", " ").strip()
            full_datetime = f"{date_str}_{time_str}"
        else:
            full_datetime = date_str
        # -------------------------------------------------------

        start_idx = m.start()
        word_index = len(final_text[:start_idx].split())
        matches.append({
            "datetime": full_datetime,
            "word_index": word_index,
            "char_index": start_idx
        })

    if not matches:
        return {}

    section = {}
    header_count = {}

    for i, m in enumerate(matches):
        if not all(k in m for k in ("char_index", "datetime", "word_index")):
            continue

        full_datetime = m["datetime"]
        word_index = m["word_index"]

        # nearest visit type
        nearest_visit = None
        nearest_visit_idx = None
        for vm in visit_pattern.finditer(final_text):
            v_word_idx = len(final_text[:vm.start()].split())
            if abs(v_word_idx - word_index) <= 60:
                nearest_visit = vm.group(0).strip()
                nearest_visit_idx = vm.start()
                break

        if not nearest_visit:
            continue

        start = m["char_index"]

        # default end = next date
        if i + 1 < len(matches):
            end = matches[i + 1]["char_index"]
        else:
            end = len(final_text)

        # check for "Care Timeline"
        search_area = final_text[start:end]

        # page detection BEFORE "Care Timeline"
        page_match = page_pattern.search(search_area)
        if page_match:
            page_no = page_match.group(1)
        else:
            page_no = "Unknown"

        # truncate at "Care Timeline" if present
        end_match = end_pattern.search(search_area)
        if end_match:
            end = start + end_match.start()

        section_text = final_text[start:end].strip()
        

        try:
            page_no_int = int(page_no)
            page_no_final = page_no_int - 1
        except (ValueError, TypeError):
            page_no_final = "Unknown"
            continue

        if page_no_final >=0 :
            page_start_index = page_Start_Index_list[page_no_final]
            if page_no_final > 0:
                page_start_index = page_Start_Index_list[page_no_final]
            if page_start_index > start:
                page_start_index = start
            
            section_text = final_text[page_start_index:end].strip()
        else:
            continue 
        section_text = remove_chunk_data_AHFL(section_text)
        if not section_text:
            continue
        full_datetime_updated = ConvertToNormalizedDOS(full_datetime)
        nearest_visit_Uniform= normalize_visit_type(nearest_visit.replace(' ', '_'))
        base_header = (
            f"DateOfService_{full_datetime_updated}_"
            f"{nearest_visit_Uniform}_"
            f"Page_{page_no_final}"
        )

        count = header_count.get(base_header, 0)
        header_count[base_header] = count + 1

        header_name = f"{base_header}"
        sections[header_name] = section_text

    return sections

